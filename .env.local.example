# Переименуй этот файл в .env.local для локальной разработки
# В Vercel добавь эти переменные через Settings → Environment Variables

# API-ключ сервисного аккаунта Yandex Cloud
YANDEX_API_KEY=your_api_key_here

# ID каталога (folder) в Yandex Cloud (видно в URL консоли)
YANDEX_FOLDER_ID=your_folder_id_here
